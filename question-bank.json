{
  "_schema_guide": {
    "version": 2,
    "description": "初中短答題目庫。每個 entry 是一個題型 metadata；實際 generator/validator 函式集中於 tool/*.js 模組。",
    "entry_fields": {
      "key": "題型唯一 key。不可與其他題型重複。",
      "name": "題型中文名（顯示用）。",
      "category": "分類名（例：數與代數 / 幾何 / 數據處理）。",
      "difficulty": "1=初階（F.1）/ 2=進階（F.2-F.3）/ 3=挑戰。",
      "type": "題型輸入類別：text / choice / coordinate / congruence。",
      "checkType": "判分方式：textExact / numeric / signedNumeric / numericOrFraction / unitNumeric / fracPct / primeFactor / algebraQ8 / hcfLcm / polyTerms / choiceKey / congruenceReason / coordinatePoint。",
      "params_schema": "題型參數定義，給 AI 生成新題型時參考。",
      "answers": "後備答案陣列（textExact / choiceKey 用）。",
      "displayAnswer": "教師答案／步驟顯示用。",
      "steps": "預設教學步驟 HTML（generate() 會覆寫）。",
      "pdfText": "列印／PDF 用的題目文字。",
      "options": "choice 題型專用：[{ key, label }]。",
      "interaction": "coordinate 題型專用：{ targetX, targetY, askAxis }。",
      "imageSvg": "congruence 題型專用：純圖像 SVG。",
      "prefix": "輸入框前綴文字（例：'x = '）。",
      "suffix": "輸入框後綴文字。",
      "grade": "年級 key（例：s1 / s2 / s3）。空字串代表未分類。",
      "term": "學期 key（1 / 2 / 3 / all）。空字串代表未分類。",
      "topicKey": "課題 key（例：number_and_algebra）。",
      "topicName": "課題顯示名稱（例：數與代數）。",
      "schemaVersion": "題型 schema 版本；目前為 1。",
      "part": "卷別／部分，例如 part_a；示範題可用 demo。",
      "validator": "validator registry key；現階段由 checkType alias 映射而來。",
      "generator": "generator registry key；對應 tool/generators.js。",
      "defaultParams": "optional object；傳入 generator 的固定預設參數，用於同一 generator 在不同 preset 題型中保留同一家族但限制模式或答案特性。",
      "answerSpec": "互動題答案規格；coordinate 題需指定 coordinateMode。",
      "figure": "幾何／全等題圖形規格；可指向 generated SVG。",
      "code": "展示用題目編碼；校內題格式 {來源}-{學年}-{年級}-{學期}-{題號}-{課題碼}-{家族號}，例如 LSC-2526-S1-T3-01-NA-1；DSE 保留格式 DSE-{年份}-{卷別}-{部分}-{題號}-{課題碼}-{家族號}。指定後永不更改。",
      "source": "optional string；原校內題目出處或改編來源。出處不明留空字串。"
    },
    "laTeX_escape_rule": "JSON 中 LaTeX 寫 \\( 與 \\)，JSON 解析後變 \\( \\)，MathJax 收到 1 個反斜線。",
    "filter_rule": "老師工具按 grade -> term -> topicKey -> key 篩選；grade 為空嘅題型列喺『未分類』群組。",
    "param_syntax": "generate() 內用 ${paramName} 插值；插值會做 HTML escape 防止 XSS。",
    "preset_fields": {
      "key": "preset 唯一 key。",
      "name": "preset 中文名。",
      "description": "preset 簡介。",
      "questions": "題型與題數陣列。preset 引用嘅 key 必須喺 data 內存在。"
    },
    "builtin_keys_reserved": [
      "frac_arith",
      "neg_power",
      "prime_factor",
      "hcf_or_lcm",
      "exp_law",
      "alg_simplify",
